# ChainVault RWA Protocol — Environment Variables
# Copy this file to .env and fill in your keys

# ─── AI LAYER ────────────────────────────────────────────────
# Get your free Groq API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ─── ALGORAND ────────────────────────────────────────────────
# For TestNet, these defaults work without a token
ALGORAND_ALGOD_URL=https://testnet-api.algonode.cloud
ALGORAND_ALGOD_TOKEN=

# Your Algorand wallet (NEVER commit real keys — use TestNet only)
ALGORAND_PRIVATE_KEY=your_testnet_private_key
ALGORAND_ADDRESS=your_testnet_wallet_address

# ─── FRONTEND ────────────────────────────────────────────────
# Get from: https://dashboard.web3auth.io
VITE_WEB3AUTH_CLIENT_ID=your_web3auth_client_id

# ─── STORAGE ─────────────────────────────────────────────────
# Get from: https://app.pinata.cloud/developers/api-keys
PINATA_JWT=your_pinata_jwt_token
